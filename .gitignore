# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log

# Cached audio extracted from video files (reused across runs)
*.audio.wav

# Transcription outputs (do not track generated files)
# Exclude transcript outputs but keep project text files
**/*.txt
!requirements.txt
!README.md
!TECHNICAL.md
**/*.srt

# Temporary ffmpeg chunks
cepol_chunk_*/

# Secrets — never commit
.env

# Test media — drop files here for local testing, never commit
sample_media/*
!sample_media/.gitkeep

# Editor / IDE
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store

# Model cache (large binary files)
models/
~/.cache/huggingface/
