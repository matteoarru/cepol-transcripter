# CEPOL Transcripter — environment configuration template
# Copy this file to .env and fill in your values.
# .env is git-ignored; this file is safe to commit.

# GitHub personal access token (used by gh CLI for repo operations)
GITHUB_TOKEN=

# Hugging Face token — required to download gated models (e.g. large-v3-turbo)
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# CUDA device selection — restrict to specific GPU(s), e.g. "0" or "0,1"
# Leave empty to use all available GPUs.
CUDA_VISIBLE_DEVICES=

# Default chunk slot size for long media processing, in minutes.
MEDIA_CHUNK_MINUTES=20

# CPU threads used by CTranslate2.
CPU_THREADS=8

# Background extraction threads for long media pipelines.
# Values above 5 are clamped to 5.
PIPELINE_THREADS=5

# Benchmark-backed batch throughput profile for v2.0.0.
# This was the fastest setting measured locally on Ubuntu 24.04 + RTX 5000 Ada.
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_VAD=false
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
